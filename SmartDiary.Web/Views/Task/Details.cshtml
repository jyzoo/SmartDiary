@model SmartDiary.Web.Models.TodoTask

<div class="container mt-5">

    <h2>@Model.Title</h2>

    <div class="card p-3">

        <p>
            <strong>Описание:</strong>
            @Model.Description
        </p>

        <p>
            <strong>Статус:</strong>
            @Model.Status
        </p>

        <p>
            <strong>Приоритет:</strong>
            @Model.Priority
        </p>

    </div>

    <a asp-action="Index"
       class="btn btn-secondary mt-3">
        Назад
    </a>

</div>